---
import ExperienceItem from "@/components/ExperienceItem.astro";
import SectionTitle from "@/components/SectionTitle.astro";

const EXPERIENCE = [
  {
    date: "December 2022 - Present",
    yoe: "(3 years 4 months)",
    title: "Front-End Developer",
    company: "Zapp Studio",
    link: "https://zapp-studio.com/",
    description:
      "Served as the primary frontend developer on a national-scale agricultural management platform built with Angular 14, acting as direct technical contact with the client. Architected and maintained multiple CMS platforms using Nuxt 2/3/4 and Vuetify for user management, content administration and role-based access workflows. Developed a cross-platform mobile application using Ionic with integrated AI-powered chat, in-app payment processing and real-time messaging. Currently specializing in agentive development, orchestrating AI coding agents (Claude, OpenCode, Codex) to automate and augment software development workflows, and applying Spec-Driven Development (SDD) methodologies to build more reliable and reproducible systems, as part of a transition toward AI Engineering.",
  },
  {
    date: "March 2022 - November 2022",
    yoe: "(9 months)",
    title: "Web Developer",
    company: "Capgemini",
    link: "https://www.capgemini.com/es-es/",
    description:
      "Co-led a research initiative evaluating immersive 3D web technologies including Three.js, React Three Fiber and Angular Three, prototyping interactive virtual environments with real-time physics, animations and collision detection across multiple JavaScript frameworks. Delivered all findings in an internal English-language presentation to over 200 employees.",
  },
];
---

<SectionTitle title="Experience" />

<ol class="relative border-s-2 border-neutral-300">
  {
    EXPERIENCE.map((experience) => (
      <li class="mb-10 ms-4">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>
